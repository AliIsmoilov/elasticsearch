# Example environment variables for local development

# Postgres (used when DATABASE_URL is not set)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpass
POSTGRES_DB=dbname

# Alternatively, set a DATABASE_URL environment variable
# DATABASE_URL=postgres://dbuser:dbpass@postgres:5432/dbname?sslmode=disable

# Elasticsearch address
ELASTIC_ADDR=http://elasticsearch:9200
